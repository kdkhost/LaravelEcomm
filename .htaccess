<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes
    RewriteEngine On

    # Do not expose /public in the browser URL.
    RewriteCond %{THE_REQUEST} \s/+public/([^\s?]*) [NC]
    RewriteRule ^public/(.*)$ /$1 [R=301,L,NE]

    # Serve real public assets while the cPanel document root points to the project root.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.*)$ public/$1 [L]

    # Block direct access to Laravel internals when the whole project is in public_html.
    RewriteRule ^(app|bootstrap|config|database|Modules|resources|routes|storage|tests|vendor)(/|$) - [F,L,NC]

    # Send application routes to Laravel's front controller.
    RewriteRule ^$ public/index.php [L]
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>

<FilesMatch "^(\.env|\.git|\.gitattributes|\.gitignore|composer\.(json|lock)|package(-lock)?\.json|artisan|server\.php|webpack\.mix\.js|vite\.config\.js|phpunit\.xml|openapi\.yaml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
