APP_NAME="Loja Rataplam"
APP_ENV=local
APP_KEY=base64:7hVx8R+WzZIXAyXs7rcmFo4NCxWE6jNALbrHvd2eNAg=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt

# TRUSTED_PROXIES=*   (descomente se usar Cloudflare)

LOG_CHANNEL=stack

# =============================================================================
# BANCO DE DADOS
# =============================================================================
# Opção 1: SQLite (local/desenvolvimento)
DB_CONNECTION=sqlite
# Opção 2: MySQL (cPanel/produção) — comente as 2 linhas acima e descomente abaixo:
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=seu_banco
# DB_USERNAME=seu_usuario
# DB_PASSWORD=sua_senha

# =============================================================================
# CACHE — use 'file' se não tiver Redis
# =============================================================================
CACHE_STORE=file

# =============================================================================
# FILA (QUEUE)
# =============================================================================
QUEUE_CONNECTION=sync

# =============================================================================
# SESSÃO
# =============================================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120

# =============================================================================
# SCOUT (busca) — 'database' dispensa Elasticsearch
# =============================================================================
SCOUT_DRIVER=database

# =============================================================================
# REDIS — opcional, desabilitado por padrão
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# E-MAIL
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@rataplam.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# MERCADO PAGO
# =============================================================================
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_SANDBOX=true

# =============================================================================
# PAYPAL
# =============================================================================
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=

# =============================================================================
# RECURSOS DESABILITADOS (não use em cPanel sem os serviços)
# =============================================================================
TELESCOPE_ENABLED=false
MULTI_TENANT_ENABLED=false
BROADCAST_DRIVER=log
ENABLE_OPENAI=false
OPENAI_API_KEY=

# =============================================================================
# AWS (opcional, para uploads em S3)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# =============================================================================
# TEMA
# =============================================================================
ACTIVE_TEMPLATE=default

# =============================================================================
# BLAZE (template engine otimizada)
# =============================================================================
BLAZE_ENABLED=true
BLAZE_DEBUG=false
BLAZE_THROW=false
BLAZE_CACHE_WARM=true
