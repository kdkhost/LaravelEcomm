# =============================================================================
# LOJA RATAPLAM - Configuração de Ambiente
# =============================================================================
# Copie este arquivo como .env e ajuste as variáveis conforme seu ambiente.
#   cp .env.example .env
#
# CloudLinux + PHP 8.4: funciona perfeitamente. Apenas garanta que as
# extensões pdo_mysql, mbstring, xml, curl, gd, intl, zip, bcmath estejam
# habilitadas no "Selecionar versão do PHP" do cPanel.
# =============================================================================

# =============================================================================
# APLICAÇÃO
# =============================================================================
APP_NAME="Loja Rataplam"
APP_ENV=local
# Gere com: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt

# IDs dos idiomas na tabela 'languages' (0 = desativado)
APP_LANGUAGE_ID=1
APP_FALLBACK_LANGUAGE_ID=1

# Fuso horário
APP_TIMEZONE=America/Sao_Paulo

# Moeda
APP_CURRENCY=BRL
APP_CURRENCY_SYMBOL=R$

# =============================================================================
# LOG
# =============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# =============================================================================
# BANCO DE DADOS
# =============================================================================
# OPÇÃO 1: SQLite (recomendado para desenvolvimento local)
# -----------------------------------------------
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# OPÇÃO 2: MySQL (produção - cPanel/CloudLinux)
# -----------------------------------------------
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=lojavirtual_rataplam
# DB_USERNAME=lojavirtual_rataplam
# DB_PASSWORD=83388601Mm...

# OPÇÃO 3: PostgreSQL
# -----------------------------------------------
# DB_CONNECTION=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=lojavirtual_rataplam
# DB_USERNAME=lojavirtual_rataplam
# DB_PASSWORD=sua_senha

# =============================================================================
# BANCO DO OWNER (usado para multi-tenancy - ignorar se não usar)
# =============================================================================
OWNER_DB_CONNECTION=sqlite
OWNER_DB_DATABASE=database/owner.sqlite

# =============================================================================
# CACHE
# =============================================================================
# Opções: file, redis, memcached, database
CACHE_STORE=file
CACHE_PREFIX=rataplam_cache

# TTL padrão do cache em segundos (14400 = 4 horas)
CACHE_TTL=14400

# Prefixo do cache do tenant (multi-tenancy)
# TENANT_CACHE_PREFIX=rataplam_t

# =============================================================================
# FILA (QUEUE)
# =============================================================================
# Opções: sync, database, redis, beanstalkd, sqs
# sync = executa na hora (sem fila) - ideal para dev
QUEUE_CONNECTION=sync

# =============================================================================
# SESSÃO
# =============================================================================
# Opções: file, cookie, database, redis, array
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# =============================================================================
# REDIS
# =============================================================================
# Opcional - só configure se tiver Redis instalado
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis
REDIS_CLUSTER=predis

# =============================================================================
# SCOUT (MOTOR DE BUSCA)
# =============================================================================
# Opções:
#   database   = busca SQL básica (não precisa de serviço externo)
#   collection = busca em coleção (não precisa de serviço externo)
#   elastic    = Elasticsearch (requer servidor Elastic)
#   algolia    = Algolia (requer conta Algolia)
SCOUT_DRIVER=database

# Elasticsearch (se usar SCOUT_DRIVER=elastic):
# SCOUT_ELASTIC_HOST=localhost:9200
# SCOUT_ELASTIC_INDEX=rataplam_products

# Algolia (se usar SCOUT_DRIVER=algolia):
# ALGOLIA_APP_ID=sua_app_id
# ALGOLIA_SECRET=sua_secret

# =============================================================================
# E-MAIL
# =============================================================================
# Opções: smtp, sendmail, mailgun, ses, postmark, log, array
# log = salva em storage/logs (ideal para dev)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@rataplam.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun (se usar MAIL_MAILER=mailgun):
# MAILGUN_DOMAIN=seu_dominio
# MAILGUN_SECRET=sua_chave
# MAILGUN_ENDPOINT=api.mailgun.net

# SES (se usar MAIL_MAILER=ses):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# MERCADO PAGO
# =============================================================================
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_SANDBOX=true

# Webhook secreto (opcional, para validar notificações do Mercado Pago)
# MERCADO_PAGO_WEBHOOK_SECRET=

# =============================================================================
# PAYPAL
# =============================================================================
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# OPENAI (Geração automática de descrições, SEO, etc.)
# =============================================================================
ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# AWS (upload de arquivos em S3)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# PUSHER (WebSockets em tempo real)
# =============================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =============================================================================
# RECURSOS OPCIONAIS (desabilitar se não tiver os serviços)
# =============================================================================
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# Broadcasting: log, pusher, redis, null
BROADCAST_DRIVER=log

# =============================================================================
# MULTI-TENANCY (várias lojas no mesmo sistema)
# =============================================================================
# Desabilitado por padrão - só ative se for usar múltiplos tenants
MULTI_TENANT_ENABLED=false
TENANT_MAIN_DOMAIN=localhost
TENANT_DB_PREFIX=tenant_
TENANT_ISOLATE_USERS=true

# Middleware e prefixo admin do tenant
# MULTI_TENANT_ADMIN_MIDDLEWARE=web
# MULTI_TENANT_ADMIN_PATH_PREFIX=admin

# =============================================================================
# TEMA ATIVO
# =============================================================================
# Opções: default, modern, sport
ACTIVE_TEMPLATE=default

# =============================================================================
# BLAZE (MOTOR DE TEMPLATE OTIMIZADO)
# =============================================================================
# Fork otimizado do Blade com View::share() e View::composer()
BLAZE_ENABLED=true
BLAZE_DEBUG=false
BLAZE_THROW=false
BLAZE_CACHE_WARM=true

# =============================================================================
# SEGURANÇA
# =============================================================================
# Confie em proxies reversos (Cloudflare, etc.)
# Descomente se usar Cloudflare:
# TRUSTED_PROXIES=*

# Hash de senha (bcrypt é o padrão)
HASH_DRIVER=bcrypt

# =============================================================================
# LARAVEL LOGGER (registro de atividades)
# =============================================================================
LARAVEL_LOGGER_DATABASE_CONNECTION=sqlite
LARAVEL_LOGGER_DATABASE_TABLE=laravel_logger_activity
LARAVEL_LOGGER_ROLES_ENABLED=true
LARAVEL_LOGGER_MIDDLEWARE_ENABLED=true
LARAVEL_LOGGER_USER_MODEL=Modules\User\Models\User
LARAVEL_LOGGER_USER_ID_FIELD=id
LARAVEL_LOGGER_PAGINATION_ENABLED=true
LARAVEL_LOGGER_PAGINATION_PER_PAGE=25
LARAVEL_LOGGER_ENABLE_SEARCH=true
LARAVEL_LOGGER_DASHBOARD_MENU_ENABLED=true
LARAVEL_LOGGER_BOOTSTRAP_VERSION=4
LARAVEL_LOGGER_LAYOUT=admin::layouts.master

# =============================================================================
# LARAVEL BLOCKER (bloqueio de IP)
# =============================================================================
LARAVEL_BLOCKER_ENABLED=true
LARAVEL_BLOCKER_DATABASE_CONNECTION=sqlite
LARAVEL_BLOCKER_DATABASE_TABLE=laravel_blocker
LARAVEL_BLOCKER_USER_MODEL=Modules\User\Models\User
LARAVEL_BLOCKER_DEFAULT_ACTION=abort
LARAVEL_BLOCKER_DEFAULT_ACTION_ABORT_TYPE=403
LARAVEL_BLOCKER_AUTH_ENABLED=true

# =============================================================================
# SANCTUM (API tokens)
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DOMAIN=null
