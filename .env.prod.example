# =============================================================================
# LOJA RATAPLAM - PRODUÇÃO (cPanel + CloudLinux + LiteSpeed)
# =============================================================================
# Copie este arquivo para .env no servidor de produção.
# CloudLinux + PHP 8.4 é totalmento compatível com Laravel 11/12.
# Apenas garanta no PHP Selector: pdo_mysql, mbstring, xml, curl, gd,
# intl, zip, bcmath, openssl, tokenizer, json, ctype, fileinfo ativos.
# =============================================================================

# =============================================================================
# APLICAÇÃO
# =============================================================================
APP_NAME="Loja Rataplam"
APP_ENV=production
APP_KEY=base64:7hVx8R+WzZIXAyXs7rcmFo4NCxWE6jNALbrHvd2eNAg=
APP_DEBUG=false
APP_URL=http://loja.km.site.nom.br
APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_TIMEZONE=America/Sao_Paulo
APP_CURRENCY=BRL
APP_CURRENCY_SYMBOL=R$
APP_LANGUAGE_ID=1
APP_FALLBACK_LANGUAGE_ID=1

# =============================================================================
# LOG - em produção só avisos+erros
# =============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DAILY_DAYS=7

# =============================================================================
# BANCO DE DADOS - MySQL (cPanel)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=lojavirtual_rataplam
DB_USERNAME=lojavirtual_rataplam
DB_PASSWORD=83388601Mm...

# =============================================================================
# CACHE - file é o único sem dependência externa em cPanel compartilhado
# =============================================================================
CACHE_STORE=file
CACHE_PREFIX=rataplam_prod
CACHE_TTL=14400

# =============================================================================
# FILA (QUEUE) - database usa tabela jobs, sem Redis
# =============================================================================
QUEUE_CONNECTION=database

# =============================================================================
# SESSÃO
# =============================================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/

# =============================================================================
# REDIS - desligado em cPanel compartilhado (não temos Redis)
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# SCOUT (MOTOR DE BUSCA)
# =============================================================================
# database = busca SQL pura (não precisa de serviço externo)
SCOUT_DRIVER=database

# =============================================================================
# E-MAIL
# =============================================================================
# Configure SMTP transacional (Mailgun, SendGrid, Brevo, etc.)
# Mailtrap NÃO funciona em produção - só para testes
MAIL_MAILER=smtp
MAIL_HOST=smtp.titan.email
MAIL_PORT=587
MAIL_USERNAME=noreply@rataplam.com.br
MAIL_PASSWORD=coloque_a_senha_aqui
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@rataplam.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# MERCADO PAGO
# =============================================================================
# Access Token de produção (painel Mercado Pago > Credenciais)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-1234567890123456-123456-abc123def456abc123def456abc123de-123456789
MERCADO_PAGO_SANDBOX=false

# =============================================================================
# PAYPAL
# =============================================================================
# Deixe vazio se não for usar PayPal
PAYPAL_MODE=live
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# OPENAI (geração de conteúdo)
# =============================================================================
ENABLE_OPENAI=false
OPENAI_API_KEY=

# =============================================================================
# AWS (S3 para uploads - opcional)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# =============================================================================
# PUSHER (WebSockets)
# =============================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# =============================================================================
# RECURSOS DESATIVADOS EM PRODUÇÃO
# =============================================================================
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
BROADCAST_DRIVER=log
MULTI_TENANT_ENABLED=false
ENABLE_OPENAI=false

# =============================================================================
# SEGURANÇA - Cloudflare
# =============================================================================
TRUSTED_PROXIES=*

# =============================================================================
# TEMA
# =============================================================================
ACTIVE_TEMPLATE=default

# =============================================================================
# BLAZE
# =============================================================================
BLAZE_ENABLED=true
BLAZE_DEBUG=false
BLAZE_THROW=false
BLAZE_CACHE_WARM=true
