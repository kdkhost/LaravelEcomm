APP_NAME="LaravelEcomm"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seudominio.com.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=pt_BR
APP_CURRENCY_SYMBOL="R$"
APP_CURRENCY_CODE=BRL
DEFAULT_COUNTRY=BR
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo
BASE_CURRENCY=BRL

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanel_usuario_banco
DB_USERNAME=cpanel_usuario_user
DB_PASSWORD="troque-esta-senha"

OWNER_DB_CONNECTION=owner
OWNER_DB_HOST=localhost
OWNER_DB_PORT=3306
OWNER_DB_DATABASE=cpanel_usuario_owner
OWNER_DB_USERNAME=cpanel_usuario_user
OWNER_DB_PASSWORD="troque-esta-senha"

BROADCAST_DRIVER=log
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=public
FILESYSTEM_PUBLIC_ROOT=/home/usuario/public_html/public/storage
FILESYSTEM_PUBLIC_URL=https://seudominio.com.br/storage

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis
HORIZON_DOMAIN=
HORIZON_PATH=horizon

MAIL_MAILER=smtp
MAIL_HOST=mail.seudominio.com.br
MAIL_PORT=587
MAIL_USERNAME=contato@seudominio.com.br
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=contato@seudominio.com.br
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

LARAVEL_LOGGER_DATABASE_CONNECTION=mysql
LARAVEL_LOGGER_DATABASE_TABLE=laravel_logger_activity
LARAVEL_LOGGER_ROLES_ENABLED=true
LARAVEL_LOGGER_MIDDLEWARE_ENABLED=true
LARAVEL_LOGGER_USER_MODEL=Modules\User\Models\User
LARAVEL_LOGGER_USER_ID_FIELD=id
LARAVEL_LOGGER_DISABLE_ROUTES=false
LARAVEL_LOGGER_PAGINATION_ENABLED=true
LARAVEL_LOGGER_PAGINATION_PER_PAGE=25
LARAVEL_LOGGER_ENABLE_SEARCH=true
LARAVEL_LOGGER_LAYOUT=admin::layouts.master
LARAVEL_LOGGER_BOOTSTRAP_VERSION=4

PAYPAL_MODE=production
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_CURRENCY=BRL
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CURRENCY=brl

MERCADOPAGO_ENABLED=true
MERCADOPAGO_ENVIRONMENT=production
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_STATEMENT_DESCRIPTOR=LOJA VIRTUAL

CORREIOS_ENABLED=true
CORREIOS_CONTRACT_ENABLED=false
CORREIOS_ORIGIN_CEP=
CORREIOS_ACCESS_TOKEN=
CORREIOS_CONTRACT_NUMBER=
CORREIOS_REGIONAL_CODE=
CORREIOS_SERVICE_CODES=03220:SEDEX,03298:PAC
CORREIOS_PRECO_BASE_URL=https://api.correios.com.br/preco/v1
CORREIOS_PRAZO_BASE_URL=https://api.correios.com.br/prazo/v1
CORREIOS_TIMEOUT=8
CORREIOS_DEFAULT_WEIGHT_GRAMS=300
CORREIOS_WEIGHT_UNIT=kg
CORREIOS_DEFAULT_LENGTH_CM=20
CORREIOS_DEFAULT_WIDTH_CM=15
CORREIOS_DEFAULT_HEIGHT_CM=5

ELASTICSEARCH_HOST=127.0.0.1
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_INDEX=products
ENABLE_OPENAI=false
OPENAI_API_KEY=

MULTI_TENANT_ENABLED=true
BLAZE_ENABLED=true
BLAZE_DEBUG=false
BLAZE_THROW=false
BLAZE_CACHE_WARM=true

ACTIVE_TEMPLATE=default
FRONT_ACTIVE_TEMPLATE=default
